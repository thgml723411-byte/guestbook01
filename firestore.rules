rules_version = '2';

// firebase 콘솔 > Firestore Database > 규칙 탭에 이 내용을 붙여넣거나
// firebase CLI(firebase deploy --only firestore:rules)로 배포해서 사용
service cloud.firestore {
  match /databases/{database}/documents {

    // 방명록 글 컬렉션 (guestbookPosts)
    match /guestbookPosts/{postId} {

      // 조회는 비회원도 가능 (읽기 전용 허용)
      allow read: if true;

      // 작성은 로그인한 회원만 가능
      // - uid는 반드시 본인의 uid로만 저장 가능 (다른 사람 명의로 작성 방지)
      // - nickname, message 값 형식/길이 검증
      // - character는 문자열이거나 비어있는 값만 허용
      // - createdAt은 반드시 서버 시간으로만 기록 가능 (클라이언트 조작 방지)
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.nickname is string
                    && request.resource.data.nickname.size() > 0
                    && request.resource.data.nickname.size() <= 20
                    && request.resource.data.message is string
                    && request.resource.data.message.size() > 0
                    && request.resource.data.message.size() <= 500
                    && (
                         !('character' in request.resource.data)
                         || request.resource.data.character is string
                         || request.resource.data.character == null
                       )
                    && request.resource.data.createdAt == request.time;

      // 수정은 로그인한 "작성자 본인"만 가능
      // - 기존 글의 uid(작성자), nickname, createdAt은 수정 요청으로 바꿀 수 없음
      // - 새 message 값도 형식/길이 검증
      allow update: if request.auth != null
                    && resource.data.uid == request.auth.uid
                    && request.resource.data.uid == resource.data.uid
                    && request.resource.data.nickname == resource.data.nickname
                    && request.resource.data.createdAt == resource.data.createdAt
                    && request.resource.data.message is string
                    && request.resource.data.message.size() > 0
                    && request.resource.data.message.size() <= 500;

      // 삭제는 로그인한 "작성자 본인"만 가능
      allow delete: if request.auth != null
                    && resource.data.uid == request.auth.uid;
    }

    // 위에서 명시하지 않은 나머지 모든 문서는 기본적으로 접근 차단
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
